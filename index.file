
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ALP Supervool LLC — Caribbean Freight Authority</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400;600;700;800;900&family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --navy-deep:   #030b18;
    --navy-mid:    #071629;
    --navy-light:  #0d2240;
    --slate:       #1a3354;
    --blue-neon:   #00c8ff;
    --blue-glow:   #0088dd;
    --blue-dim:    #004a80;
    --amber:       #ffb830;
    --white:       #e8f4ff;
    --muted:       #5b7fa6;
    --tier1:       #00c8ff;
    --tier2:       #0088dd;
    --tier3:       #ffb830;
    --font-display: 'Barlow Condensed', sans-serif;
    --font-body:    'IBM Plex Sans', sans-serif;
    --font-mono:    'IBM Plex Mono', monospace;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--navy-deep);
    color: var(--white);
    font-family: var(--font-body);
    overflow-x: hidden;
  }

  /* ─── NOISE OVERLAY ─── */
  body::before {
    content: '';
    position: fixed; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none; z-index: 9999; opacity: 0.4;
  }

  /* ─── NAV ─── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 3rem;
    background: linear-gradient(to bottom, rgba(3,11,24,0.95), transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(0,200,255,0.08);
  }

  .nav-logo {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.6rem;
    letter-spacing: 0.12em;
    color: var(--white);
    text-transform: uppercase;
  }

  .nav-logo span { color: var(--blue-neon); }

  .nav-links { display: flex; gap: 2.5rem; list-style: none; }

  .nav-links a {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--blue-neon); }

  .nav-cta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.6rem 1.4rem;
    border: 1px solid var(--blue-neon);
    color: var(--blue-neon);
    background: transparent;
    cursor: pointer;
    transition: all 0.25s;
  }

  .nav-cta:hover {
    background: var(--blue-neon);
    color: var(--navy-deep);
    box-shadow: 0 0 24px rgba(0,200,255,0.4);
  }

  /* ─── HERO ─── */
  #hero {
    min-height: 100vh;
    display: flex; flex-direction: column; justify-content: center;
    position: relative;
    overflow: hidden;
    padding: 8rem 3rem 4rem;
  }

  .hero-grid-bg {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(0,136,221,0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,136,221,0.06) 1px, transparent 1px);
    background-size: 60px 60px;
    animation: grid-drift 20s linear infinite;
  }

  @keyframes grid-drift {
    from { transform: translateX(0); }
    to { transform: translateX(60px); }
  }

  .hero-radial {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(0,136,221,0.14) 0%, transparent 70%);
  }

  .hero-scanline {
    position: absolute; top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--blue-neon), transparent);
    animation: scanline 4s ease-in-out infinite;
    opacity: 0.6;
  }

  @keyframes scanline {
    0% { top: 0%; opacity: 0; }
    10% { opacity: 0.6; }
    90% { opacity: 0.6; }
    100% { top: 100%; opacity: 0; }
  }

  .hero-content { position: relative; z-index: 2; max-width: 900px; }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.35em;
    color: var(--blue-neon);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    display: flex; align-items: center; gap: 1rem;
  }

  .hero-eyebrow::before {
    content: '';
    display: inline-block;
    width: 40px; height: 1px;
    background: var(--blue-neon);
    box-shadow: 0 0 8px var(--blue-neon);
  }

  .hero-headline {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(3rem, 7vw, 7rem);
    line-height: 0.92;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    margin-bottom: 2rem;
  }

  .hero-headline .accent { color: var(--blue-neon); text-shadow: 0 0 40px rgba(0,200,255,0.5); }
  .hero-headline .light { color: var(--muted); font-weight: 300; }

  .hero-sub {
    font-size: 1.05rem;
    color: rgba(232,244,255,0.65);
    line-height: 1.7;
    max-width: 560px;
    margin-bottom: 3rem;
    font-weight: 300;
  }

  .hero-actions { display: flex; gap: 1.2rem; flex-wrap: wrap; }

  .btn-primary {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 1rem 2.5rem;
    background: var(--blue-neon);
    color: var(--navy-deep);
    border: none; cursor: pointer;
    position: relative; overflow: hidden;
    transition: all 0.3s;
    clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));
  }

  .btn-primary:hover {
    background: #33d4ff;
    box-shadow: 0 0 40px rgba(0,200,255,0.6), 0 0 80px rgba(0,200,255,0.2);
    transform: translateY(-2px);
  }

  .btn-secondary {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 1rem 2.5rem;
    background: transparent;
    color: var(--white);
    border: 1px solid rgba(232,244,255,0.25);
    cursor: pointer;
    transition: all 0.3s;
    clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));
  }

  .btn-secondary:hover {
    border-color: var(--blue-neon);
    color: var(--blue-neon);
    background: rgba(0,200,255,0.05);
  }

  /* Hero Stats Bar */
  .hero-stats {
    position: absolute; bottom: 3rem; left: 3rem; right: 3rem;
    display: flex; gap: 0;
    border-top: 1px solid rgba(0,200,255,0.15);
    padding-top: 2rem;
    z-index: 2;
  }

  .stat-item {
    flex: 1;
    padding: 0 2rem;
    border-right: 1px solid rgba(0,200,255,0.1);
  }

  .stat-item:first-child { padding-left: 0; }
  .stat-item:last-child { border-right: none; }

  .stat-number {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 2.5rem;
    color: var(--blue-neon);
    line-height: 1;
    text-shadow: 0 0 20px rgba(0,200,255,0.4);
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: var(--muted);
    text-transform: uppercase;
    margin-top: 0.4rem;
  }

  /* Moving ships animation */
  .hero-ships {
    position: absolute; right: 0; top: 50%; transform: translateY(-50%);
    width: 45%; height: 60%; opacity: 0.12;
    pointer-events: none;
  }

  /* ─── SECTION COMMON ─── */
  section { padding: 7rem 3rem; position: relative; }

  .section-header { margin-bottom: 4rem; }

  .section-tag {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.35em;
    color: var(--blue-neon);
    text-transform: uppercase;
    display: flex; align-items: center; gap: 0.8rem;
    margin-bottom: 1rem;
  }

  .section-tag::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, rgba(0,200,255,0.3), transparent);
    max-width: 100px;
  }

  .section-title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    text-transform: uppercase;
    line-height: 0.95;
  }

  .section-title .accent { color: var(--blue-neon); }

  /* ─── ROUTE / MAP SECTION ─── */
  #map-section {
    background: var(--navy-mid);
    border-top: 1px solid rgba(0,200,255,0.08);
    border-bottom: 1px solid rgba(0,200,255,0.08);
  }

  .map-wrapper {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    align-items: start;
  }

  .map-info p {
    color: rgba(232,244,255,0.6);
    line-height: 1.8;
    font-size: 0.95rem;
    margin-bottom: 2rem;
    font-weight: 300;
  }

  .route-list { list-style: none; }

  .route-item {
    display: flex; align-items: center; gap: 1rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(0,200,255,0.07);
    cursor: pointer;
    transition: all 0.2s;
  }

  .route-item:hover { padding-left: 0.5rem; }

  .route-item:hover .route-dot { box-shadow: 0 0 12px var(--blue-neon); }

  .route-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--blue-neon);
    flex-shrink: 0;
    transition: box-shadow 0.2s;
  }

  .route-name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    flex: 1;
  }

  .route-time {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--muted);
    letter-spacing: 0.1em;
  }

  /* SVG Map */
  .map-svg-container {
    position: relative;
    border: 1px solid rgba(0,200,255,0.12);
    background: rgba(3,11,24,0.6);
    padding: 1.5rem;
  }

  .map-svg-container::before {
    content: 'LIVE ROUTE SIMULATION';
    position: absolute;
    top: -1px; left: 2rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: var(--blue-neon);
    background: var(--navy-mid);
    padding: 0 0.5rem;
    transform: translateY(-50%);
  }

  #logistics-map { width: 100%; height: auto; display: block; }

  /* ─── TIERS ─── */
  #tiers { background: var(--navy-deep); }

  .tiers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5px;
    background: rgba(0,200,255,0.08);
    border: 1px solid rgba(0,200,255,0.08);
  }

  .tier-card {
    background: var(--navy-mid);
    padding: 2.5rem;
    position: relative;
    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    overflow: hidden;
    cursor: pointer;
  }

  .tier-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0;
    height: 3px;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .tier-card:nth-child(1)::before { background: var(--tier1); }
  .tier-card:nth-child(2)::before { background: var(--tier2); box-shadow: 0 0 20px var(--tier2); }
  .tier-card:nth-child(3)::before { background: var(--tier3); }

  .tier-card::after {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(0,200,255,0.06) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.4s;
  }

  .tier-card:hover {
    transform: translateY(-8px);
    background: var(--navy-light);
    box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 30px rgba(0,136,221,0.1);
  }

  .tier-card:hover::before { opacity: 1; }
  .tier-card:hover::after { opacity: 1; }

  .tier-card.featured {
    background: var(--navy-light);
    border: 1px solid rgba(0,136,221,0.3);
  }

  .tier-badge {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    padding: 0.3rem 0.8rem;
    display: inline-block;
    margin-bottom: 1.5rem;
  }

  .tier-card:nth-child(1) .tier-badge { background: rgba(0,200,255,0.1); color: var(--tier1); border: 1px solid rgba(0,200,255,0.2); }
  .tier-card:nth-child(2) .tier-badge { background: rgba(0,136,221,0.15); color: #66c8ff; border: 1px solid rgba(0,136,221,0.3); }
  .tier-card:nth-child(3) .tier-badge { background: rgba(255,184,48,0.1); color: var(--tier3); border: 1px solid rgba(255,184,48,0.25); }

  .tier-name {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 2rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.3rem;
  }

  .tier-subtitle {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.15em;
    margin-bottom: 1.5rem;
  }

  .tier-price {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 900;
    margin-bottom: 0.3rem;
    line-height: 1;
  }

  .tier-card:nth-child(1) .tier-price { color: var(--tier1); }
  .tier-card:nth-child(2) .tier-price { color: #66c8ff; }
  .tier-card:nth-child(3) .tier-price { color: var(--tier3); }

  .tier-price-note {
    font-size: 0.75rem;
    color: var(--muted);
    margin-bottom: 2rem;
    font-family: var(--font-mono);
  }

  .tier-divider {
    height: 1px;
    background: rgba(0,200,255,0.1);
    margin-bottom: 1.5rem;
  }

  .tier-features { list-style: none; margin-bottom: 2.5rem; }

  .tier-features li {
    display: flex; align-items: flex-start; gap: 0.75rem;
    padding: 0.5rem 0;
    font-size: 0.88rem;
    color: rgba(232,244,255,0.75);
    line-height: 1.5;
    border-bottom: 1px solid rgba(0,200,255,0.04);
  }

  .tier-features li::before {
    content: '◆';
    font-size: 0.45rem;
    margin-top: 0.45rem;
    flex-shrink: 0;
  }

  .tier-card:nth-child(1) .tier-features li::before { color: var(--tier1); }
  .tier-card:nth-child(2) .tier-features li::before { color: #66c8ff; }
  .tier-card:nth-child(3) .tier-features li::before { color: var(--tier3); }

  .tier-cta {
    width: 100%;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.9rem;
    border: none; cursor: pointer;
    transition: all 0.3s;
    position: relative; z-index: 1;
  }

  .tier-card:nth-child(1) .tier-cta {
    background: transparent;
    color: var(--tier1);
    border: 1px solid rgba(0,200,255,0.35);
  }

  .tier-card:nth-child(1) .tier-cta:hover {
    background: rgba(0,200,255,0.1);
    box-shadow: 0 0 20px rgba(0,200,255,0.2);
  }

  .tier-card:nth-child(2) .tier-cta {
    background: var(--blue-glow);
    color: var(--white);
    box-shadow: 0 0 20px rgba(0,136,221,0.3);
  }

  .tier-card:nth-child(2) .tier-cta:hover {
    background: var(--blue-neon);
    color: var(--navy-deep);
    box-shadow: 0 0 35px rgba(0,200,255,0.5);
  }

  .tier-card:nth-child(3) .tier-cta {
    background: var(--tier3);
    color: var(--navy-deep);
  }

  .tier-card:nth-child(3) .tier-cta:hover {
    background: #ffc84a;
    box-shadow: 0 0 30px rgba(255,184,48,0.5);
  }

  /* ─── CALCULATOR ─── */
  #calculator {
    background: var(--navy-mid);
    border-top: 1px solid rgba(0,200,255,0.08);
    border-bottom: 1px solid rgba(0,200,255,0.08);
  }

  .calc-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .calc-description p {
    color: rgba(232,244,255,0.6);
    line-height: 1.8;
    font-size: 0.95rem;
    margin-bottom: 2rem;
    font-weight: 300;
  }

  .trust-points { list-style: none; }

  .trust-point {
    display: flex; gap: 1rem;
    padding: 1.2rem 0;
    border-bottom: 1px solid rgba(0,200,255,0.07);
  }

  .trust-icon {
    width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    border: 1px solid rgba(0,200,255,0.2);
    color: var(--blue-neon);
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  .trust-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.05em;
    margin-bottom: 0.2rem;
  }

  .trust-desc {
    font-size: 0.8rem;
    color: var(--muted);
    line-height: 1.5;
  }

  /* Calculator Form */
  .calc-form {
    border: 1px solid rgba(0,200,255,0.12);
    background: rgba(3,11,24,0.7);
    padding: 2.5rem;
    position: relative;
  }

  .calc-form::before {
    content: 'FREIGHT QUOTE CALCULATOR';
    position: absolute; top: -1px; left: 2rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    color: var(--blue-neon);
    background: var(--navy-mid);
    padding: 0 0.6rem;
    transform: translateY(-50%);
  }

  .form-group { margin-bottom: 1.5rem; }

  .form-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .form-select, .form-input {
    width: 100%;
    background: rgba(0,200,255,0.03);
    border: 1px solid rgba(0,200,255,0.15);
    color: var(--white);
    font-family: var(--font-body);
    font-size: 0.9rem;
    padding: 0.8rem 1rem;
    appearance: none;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .form-select:focus, .form-input:focus {
    border-color: rgba(0,200,255,0.4);
    box-shadow: 0 0 0 3px rgba(0,200,255,0.07);
  }

  .form-select option { background: var(--navy-deep); }

  .select-wrapper { position: relative; }

  .select-wrapper::after {
    content: '▾';
    position: absolute; right: 1rem; top: 50%;
    transform: translateY(-50%);
    color: var(--blue-neon);
    pointer-events: none;
  }

  .service-toggles {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
  }

  .service-toggle {
    padding: 0.7rem;
    border: 1px solid rgba(0,200,255,0.15);
    background: transparent;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
    text-align: center;
  }

  .service-toggle.active,
  .service-toggle:hover {
    border-color: var(--blue-neon);
    color: var(--blue-neon);
    background: rgba(0,200,255,0.08);
  }

  .calc-result {
    background: rgba(0,200,255,0.04);
    border: 1px solid rgba(0,200,255,0.15);
    padding: 1.5rem;
    margin-top: 1.5rem;
    display: none;
  }

  .calc-result.visible { display: block; }

  .result-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .result-range {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--blue-neon);
    text-shadow: 0 0 20px rgba(0,200,255,0.3);
  }

  .result-note {
    font-size: 0.75rem;
    color: var(--muted);
    margin-top: 0.5rem;
  }

  .calc-btn {
    width: 100%;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.1rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 1rem;
    background: var(--blue-neon);
    color: var(--navy-deep);
    border: none; cursor: pointer;
    transition: all 0.3s;
    margin-top: 0.5rem;
  }

  .calc-btn:hover {
    background: #33d4ff;
    box-shadow: 0 0 30px rgba(0,200,255,0.5);
    transform: translateY(-1px);
  }

  /* ─── PROCESS ─── */
  #process { background: var(--navy-deep); }

  .process-flow {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    position: relative;
    gap: 0;
  }

  .process-flow::before {
    content: '';
    position: absolute;
    top: 2rem; left: 10%; right: 10%;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(0,200,255,0.3) 20%, rgba(0,200,255,0.3) 80%, transparent);
  }

  .process-step {
    padding: 0 1rem;
    text-align: center;
    position: relative;
  }

  .step-number {
    width: 4rem; height: 4rem;
    border: 1px solid rgba(0,200,255,0.25);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.5rem;
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 900;
    color: var(--blue-neon);
    background: var(--navy-deep);
    position: relative; z-index: 1;
    transition: all 0.3s;
  }

  .process-step:hover .step-number {
    background: var(--navy-light);
    border-color: var(--blue-neon);
    box-shadow: 0 0 20px rgba(0,200,255,0.2);
  }

  .step-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .step-desc {
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.6;
  }

  /* ─── CONTACT / CTA BAND ─── */
  #cta {
    background: linear-gradient(135deg, var(--navy-light), var(--navy-mid));
    border-top: 1px solid rgba(0,200,255,0.15);
    text-align: center;
    padding: 6rem 3rem;
    position: relative;
    overflow: hidden;
  }

  #cta::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 70% 80% at 50% 50%, rgba(0,136,221,0.12) 0%, transparent 70%);
  }

  .cta-super {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.35em;
    color: var(--blue-neon);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .cta-headline {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(2.5rem, 5vw, 5rem);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    line-height: 0.95;
    position: relative;
  }

  .cta-headline .accent { color: var(--blue-neon); text-shadow: 0 0 30px rgba(0,200,255,0.4); }

  .cta-sub {
    color: rgba(232,244,255,0.55);
    max-width: 520px;
    margin: 0 auto 3rem;
    line-height: 1.7;
    font-weight: 300;
    position: relative;
  }

  .cta-actions {
    display: flex; gap: 1.2rem;
    justify-content: center;
    flex-wrap: wrap;
    position: relative;
  }

  /* ─── FOOTER ─── */
  footer {
    background: var(--navy-deep);
    border-top: 1px solid rgba(0,200,255,0.08);
    padding: 3rem;
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 1.5rem;
  }

  .footer-logo {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.2rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .footer-logo span { color: var(--blue-neon); }

  .footer-links { display: flex; gap: 2rem; }

  .footer-links a {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: var(--muted);
    text-decoration: none;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: var(--blue-neon); }

  .footer-copy {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--muted);
    letter-spacing: 0.1em;
  }

  /* ─── MODAL ─── */
  .modal-overlay {
    position: fixed; inset: 0;
    background: rgba(3,11,24,0.92);
    z-index: 500;
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none;
    transition: opacity 0.3s;
    backdrop-filter: blur(4px);
  }

  .modal-overlay.open { opacity: 1; pointer-events: all; }

  .modal {
    background: var(--navy-light);
    border: 1px solid rgba(0,200,255,0.2);
    padding: 3rem;
    max-width: 500px; width: 90%;
    position: relative;
    transform: translateY(20px);
    transition: transform 0.3s;
  }

  .modal-overlay.open .modal { transform: translateY(0); }

  .modal-close {
    position: absolute; top: 1.5rem; right: 1.5rem;
    background: none; border: none;
    color: var(--muted); font-size: 1.2rem; cursor: pointer;
    transition: color 0.2s;
  }

  .modal-close:hover { color: var(--blue-neon); }

  .modal-title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 900;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .modal-sub {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--blue-neon);
    letter-spacing: 0.2em;
    margin-bottom: 2rem;
  }

  /* ─── SCROLL FADE IN ─── */
  .fade-up {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .fade-up.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── ANIMATED SHIP PATH ─── */
  .ship-pulse {
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; r: 4; }
    50% { opacity: 0.4; r: 6; }
  }

  .route-line {
    stroke-dasharray: 6 4;
    animation: dash-flow 2s linear infinite;
  }

  @keyframes dash-flow {
    from { stroke-dashoffset: 20; }
    to { stroke-dashoffset: 0; }
  }

  .moving-ship {
    animation: travel-ship 6s linear infinite;
  }

  @keyframes travel-ship {
    0% { offset-distance: 0%; opacity: 0; }
    5% { opacity: 1; }
    95% { opacity: 1; }
    100% { offset-distance: 100%; opacity: 0; }
  }

  @media (max-width: 900px) {
    nav { padding: 1rem 1.5rem; }
    .nav-links { display: none; }
    section { padding: 5rem 1.5rem; }
    .map-wrapper { grid-template-columns: 1fr; }
    .tiers-grid { grid-template-columns: 1fr; }
    .calc-wrapper { grid-template-columns: 1fr; gap: 3rem; }
    .process-flow { grid-template-columns: 1fr 1fr; gap: 2rem; }
    .hero-stats { position: static; margin-top: 3rem; flex-wrap: wrap; border: none; padding: 0; border-top: 1px solid rgba(0,200,255,0.15); padding-top: 2rem; }
    .stat-item { min-width: 120px; border-right: none; border-bottom: 1px solid rgba(0,200,255,0.1); padding: 1rem 0; }
    #hero { padding: 7rem 1.5rem 3rem; }
  }

  /* Loading animation */
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .blink { animation: blink 1.2s step-end infinite; }

  /* Ticker */
  .ticker-bar {
    background: rgba(0,200,255,0.06);
    border-top: 1px solid rgba(0,200,255,0.1);
    border-bottom: 1px solid rgba(0,200,255,0.1);
    overflow: hidden;
    padding: 0.5rem 0;
  }

  .ticker-inner {
    display: flex;
    gap: 0;
    white-space: nowrap;
    animation: ticker 25s linear infinite;
  }

  .ticker-item {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: var(--muted);
    padding: 0 3rem;
    text-transform: uppercase;
  }

  .ticker-item .highlight { color: var(--blue-neon); }

  @keyframes ticker {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
</style>
</head>
<body>

<!-- ─── NAVIGATION ─── -->
<nav>
  <div class="nav-logo">ALP <span>SUPERVOOL</span></div>
  <ul class="nav-links">
    <li><a href="#map-section">Routes</a></li>
    <li><a href="#tiers">Services</a></li>
    <li><a href="#calculator">Get Quote</a></li>
    <li><a href="#process">How It Works</a></li>
  </ul>
  <button class="nav-cta" onclick="openModal()">Contact Operations</button>
</nav>

<!-- ─── HERO ─── -->
<section id="hero">
  <div class="hero-grid-bg"></div>
  <div class="hero-radial"></div>
  <div class="hero-scanline"></div>

  <!-- Decorative SVG ship silhouette -->
  <svg class="hero-ships" viewBox="0 0 600 400" fill="none" xmlns="http://www.w3.org/2000/svg">
    <g opacity="1">
      <rect x="50" y="220" width="480" height="55" rx="2" fill="rgba(0,136,221,0.5)"/>
      <rect x="100" y="160" width="260" height="65" rx="2" fill="rgba(0,136,221,0.4)"/>
      <rect x="150" y="100" width="80" height="65" rx="1" fill="rgba(0,136,221,0.35)"/>
      <rect x="250" y="80" width="50" height="85" rx="1" fill="rgba(0,136,221,0.3)"/>
      <line x1="175" y1="100" x2="175" y2="20" stroke="rgba(0,200,255,0.4)" stroke-width="2"/>
      <line x1="175" y1="20" x2="380" y2="85" stroke="rgba(0,200,255,0.2)" stroke-width="1.5"/>
      <rect x="320" y="160" width="60" height="65" rx="1" fill="rgba(0,136,221,0.3)"/>
      <rect x="390" y="185" width="50" height="40" rx="1" fill="rgba(0,136,221,0.25)"/>
      <!-- Water lines -->
      <path d="M20 280 Q80 270 140 280 Q200 290 260 280 Q320 270 380 280 Q440 290 500 280 Q560 270 590 275" stroke="rgba(0,200,255,0.2)" stroke-width="1.5" fill="none"/>
      <path d="M0 300 Q60 290 120 300 Q180 310 240 300 Q300 290 360 300 Q420 310 480 300 Q540 290 600 295" stroke="rgba(0,200,255,0.12)" stroke-width="1.5" fill="none"/>
    </g>
  </svg>

  <div class="hero-content">
    <div class="hero-eyebrow">Port Everglades Operations Center</div>
    <h1 class="hero-headline">
      From Broward<br>
      <span class="accent">To The Islands:</span><br>
      <span class="light">Seamless Freight,</span><br>
      Superior Velocity.
    </h1>
    <p class="hero-sub">
      ALP Supervool LLC delivers end-to-end Caribbean logistics from Broward County's premier freight hub.
      Trucking, container shipping, customs clearance — one operator, zero bottlenecks.
    </p>
    <div class="hero-actions">
      <button class="btn-primary" onclick="document.getElementById('calculator').scrollIntoView({behavior:'smooth'})">Get Freight Quote</button>
      <button class="btn-secondary" onclick="document.getElementById('tiers').scrollIntoView({behavior:'smooth'})">View Service Tiers</button>
    </div>
  </div>

  <div class="hero-stats">
    <div class="stat-item">
      <div class="stat-number">18+</div>
      <div class="stat-label">Caribbean Island Routes</div>
    </div>
    <div class="stat-item">
      <div class="stat-number">96H</div>
      <div class="stat-label">Avg. Broward-to-Island Time</div>
    </div>
    <div class="stat-item">
      <div class="stat-number">24/7</div>
      <div class="stat-label">Operations Monitoring</div>
    </div>
    <div class="stat-item">
      <div class="stat-number">99.2%</div>
      <div class="stat-label">On-Time Delivery Rate</div>
    </div>
  </div>
</section>

<!-- ─── TICKER ─── -->
<div class="ticker-bar">
  <div class="ticker-inner" id="ticker">
    <span class="ticker-item">▸ <span class="highlight">LIVE:</span> MV Caribbean Carrier — Nassau, Bahamas — ETA 14:30 EST</span>
    <span class="ticker-item">▸ <span class="highlight">DOCK 7:</span> FCL Container #ALPC-2847 — Kingston, Jamaica — Cleared Customs</span>
    <span class="ticker-item">▸ <span class="highlight">TRUCKING:</span> Route 95-N — 3 Active Rigs — Broward Distribution Hub</span>
    <span class="ticker-item">▸ <span class="highlight">ALERT:</span> Priority Clearance — Bridgetown, Barbados — Processing</span>
    <span class="ticker-item">▸ <span class="highlight">NEW ROUTE:</span> Saint Lucia Direct — Now Available Q3 2025</span>
    <span class="ticker-item">▸ <span class="highlight">LIVE:</span> MV Caribbean Carrier — Nassau, Bahamas — ETA 14:30 EST</span>
    <span class="ticker-item">▸ <span class="highlight">DOCK 7:</span> FCL Container #ALPC-2847 — Kingston, Jamaica — Cleared Customs</span>
    <span class="ticker-item">▸ <span class="highlight">TRUCKING:</span> Route 95-N — 3 Active Rigs — Broward Distribution Hub</span>
    <span class="ticker-item">▸ <span class="highlight">ALERT:</span> Priority Clearance — Bridgetown, Barbados — Processing</span>
    <span class="ticker-item">▸ <span class="highlight">NEW ROUTE:</span> Saint Lucia Direct — Now Available Q3 2025</span>
  </div>
</div>

<!-- ─── MAP SECTION ─── -->
<section id="map-section">
  <div class="section-header fade-up">
    <div class="section-tag">Route Network</div>
    <h2 class="section-title">Your <span class="accent">Caribbean</span><br>Gateway</h2>
  </div>

  <div class="map-wrapper">
    <div class="map-info fade-up">
      <p>Strategically positioned at Port Everglades in Broward County — America's premier gateway to the Caribbean — ALP Supervool operates direct freight corridors to 18 island destinations.</p>
      <p>Each route is engineered for maximum velocity with dedicated customs brokerage, priority berth access, and last-mile island trucking partnerships.</p>
      <ul class="route-list">
        <li class="route-item" onclick="highlightRoute('nassau')">
          <div class="route-dot"></div>
          <span class="route-name">Nassau, Bahamas</span>
          <span class="route-time">~24 HR TRANSIT</span>
        </li>
        <li class="route-item" onclick="highlightRoute('kingston')">
          <div class="route-dot"></div>
          <span class="route-name">Kingston, Jamaica</span>
          <span class="route-time">~72 HR TRANSIT</span>
        </li>
        <li class="route-item" onclick="highlightRoute('sanjuan')">
          <div class="route-dot"></div>
          <span class="route-name">San Juan, Puerto Rico</span>
          <span class="route-time">~48 HR TRANSIT</span>
        </li>
        <li class="route-item" onclick="highlightRoute('bridgetown')">
          <div class="route-dot"></div>
          <span class="route-name">Bridgetown, Barbados</span>
          <span class="route-time">~96 HR TRANSIT</span>
        </li>
        <li class="route-item" onclick="highlightRoute('trinidad')">
          <div class="route-dot"></div>
          <span class="route-name">Port of Spain, Trinidad</span>
          <span class="route-time">~96 HR TRANSIT</span>
        </li>
        <li class="route-item" onclick="highlightRoute('georgetown')">
          <div class="route-dot"></div>
          <span class="route-name">Grand Cayman</span>
          <span class="route-time">~60 HR TRANSIT</span>
        </li>
      </ul>
    </div>

    <div class="map-svg-container fade-up">
      <svg id="logistics-map" viewBox="0 0 700 480" xmlns="http://www.w3.org/2000/svg">
        <!-- Ocean BG -->
        <rect width="700" height="480" fill="#020d1c"/>
        <rect width="700" height="480" fill="url(#ocean-grad)" opacity="0.4"/>

        <!-- Grid -->
        <defs>
          <linearGradient id="ocean-grad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#031120"/>
            <stop offset="100%" stop-color="#020810"/>
          </linearGradient>
          <filter id="glow">
            <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
            <feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
          <filter id="glow-strong">
            <feGaussianBlur stdDeviation="5" result="coloredBlur"/>
            <feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
          <marker id="arrowhead" markerWidth="6" markerHeight="4" refX="3" refY="2" orient="auto">
            <polygon points="0 0, 6 2, 0 4" fill="rgba(0,200,255,0.5)"/>
          </marker>
        </defs>

        <!-- Latitude grid lines -->
        <g stroke="rgba(0,100,200,0.08)" stroke-width="0.5">
          <line x1="0" y1="80" x2="700" y2="80"/>
          <line x1="0" y1="160" x2="700" y2="160"/>
          <line x1="0" y1="240" x2="700" y2="240"/>
          <line x1="0" y1="320" x2="700" y2="320"/>
          <line x1="0" y1="400" x2="700" y2="400"/>
          <line x1="100" y1="0" x2="100" y2="480"/>
          <line x1="200" y1="0" x2="200" y2="480"/>
          <line x1="300" y1="0" x2="300" y2="480"/>
          <line x1="400" y1="0" x2="400" y2="480"/>
          <line x1="500" y1="0" x2="500" y2="480"/>
          <line x1="600" y1="0" x2="600" y2="480"/>
        </g>

        <!-- Florida landmass (simplified) -->
        <path d="M 60 30 L 90 30 L 110 50 L 120 80 L 115 130 L 105 155 L 95 170 L 85 160 L 80 140 L 70 120 L 60 100 L 50 80 L 48 55 Z"
              fill="rgba(0,80,150,0.35)" stroke="rgba(0,200,255,0.25)" stroke-width="1"/>
        <text x="58" y="100" font-family="'IBM Plex Mono'" font-size="7" fill="rgba(0,200,255,0.5)" letter-spacing="1">FLORIDA</text>

        <!-- Cuba -->
        <path d="M 160 200 Q 220 190 280 195 Q 310 200 290 215 Q 240 225 180 220 Q 155 215 160 200 Z"
              fill="rgba(0,60,120,0.3)" stroke="rgba(0,200,255,0.15)" stroke-width="0.8"/>
        <text x="195" y="210" font-family="'IBM Plex Mono'" font-size="7" fill="rgba(0,200,255,0.4)">CUBA</text>

        <!-- Hispaniola -->
        <path d="M 310 210 Q 355 205 370 215 Q 365 230 325 235 Q 305 228 310 210 Z"
              fill="rgba(0,60,120,0.3)" stroke="rgba(0,200,255,0.15)" stroke-width="0.8"/>

        <!-- Puerto Rico -->
        <rect x="395" y="215" width="30" height="14" rx="2" fill="rgba(0,60,120,0.4)" stroke="rgba(0,200,255,0.2)" stroke-width="0.8"/>

        <!-- Jamaica -->
        <ellipse cx="260" cy="248" rx="18" ry="9" fill="rgba(0,60,120,0.35)" stroke="rgba(0,200,255,0.15)" stroke-width="0.8"/>

        <!-- Bahamas chain -->
        <g fill="rgba(0,100,180,0.4)" stroke="rgba(0,200,255,0.2)" stroke-width="0.5">
          <ellipse cx="165" cy="155" rx="10" ry="5"/>
          <ellipse cx="185" cy="165" rx="8" ry="4"/>
          <ellipse cx="200" cy="175" rx="6" ry="3"/>
        </g>

        <!-- Lesser Antilles -->
        <g fill="rgba(0,50,110,0.4)" stroke="rgba(0,200,255,0.15)" stroke-width="0.5">
          <circle cx="445" cy="230" r="5"/>
          <circle cx="455" cy="248" r="4"/>
          <circle cx="460" cy="265" r="4"/>
          <circle cx="462" cy="282" r="3"/>
          <circle cx="460" cy="298" r="5"/> <!-- Barbados area -->
          <circle cx="455" cy="315" r="4"/>
          <circle cx="450" cy="330" r="3"/>
        </g>

        <!-- Trinidad -->
        <rect x="440" y="348" width="20" height="10" rx="2" fill="rgba(0,60,120,0.4)" stroke="rgba(0,200,255,0.15)" stroke-width="0.8"/>

        <!-- Grand Cayman -->
        <ellipse cx="215" cy="268" rx="8" ry="4" fill="rgba(0,60,120,0.35)" stroke="rgba(0,200,255,0.15)" stroke-width="0.8"/>

        <!-- PORT EVERGLADES HUB (Broward origin) -->
        <!-- Glow circle -->
        <circle cx="88" cy="165" r="18" fill="rgba(0,200,255,0.05)" stroke="rgba(0,200,255,0.2)" stroke-width="1"/>
        <circle cx="88" cy="165" r="12" fill="rgba(0,200,255,0.08)" stroke="rgba(0,200,255,0.4)" stroke-width="1.5" filter="url(#glow)"/>
        <circle cx="88" cy="165" r="5" fill="#00c8ff" filter="url(#glow-strong)" class="ship-pulse"/>
        <text x="100" y="163" font-family="'IBM Plex Mono'" font-size="7.5" fill="#00c8ff" letter-spacing="0.5" font-weight="500">PORT</text>
        <text x="100" y="173" font-family="'IBM Plex Mono'" font-size="7.5" fill="#00c8ff" letter-spacing="0.5" font-weight="500">EVERGLADES</text>

        <!-- ROUTES from Port Everglades (88,165) to destinations -->

        <!-- to Nassau (170,155) -->
        <path id="r-nassau" d="M 93 163 Q 130 150 168 155" stroke="rgba(0,200,255,0.5)" stroke-width="1.5" fill="none" stroke-dasharray="5 3" class="route-line" marker-end="url(#arrowhead)"/>

        <!-- to Kingston Jamaica (260,248) -->
        <path id="r-kingston" d="M 90 170 Q 160 220 255 248" stroke="rgba(0,180,255,0.4)" stroke-width="1.5" fill="none" stroke-dasharray="5 3" class="route-line" marker-end="url(#arrowhead)"/>

        <!-- to San Juan PR (405,218) -->
        <path id="r-sanjuan" d="M 93 163 Q 250 130 400 220" stroke="rgba(0,160,255,0.4)" stroke-width="1.5" fill="none" stroke-dasharray="5 3" class="route-line" marker-end="url(#arrowhead)"/>

        <!-- to Barbados (460,298) -->
        <path id="r-bridgetown" d="M 93 166 Q 300 200 455 295" stroke="rgba(0,140,220,0.35)" stroke-width="1.5" fill="none" stroke-dasharray="5 3" class="route-line" marker-end="url(#arrowhead)"/>

        <!-- to Trinidad (448,350) -->
        <path id="r-trinidad" d="M 93 167 Q 310 250 445 347" stroke="rgba(0,120,200,0.35)" stroke-width="1.5" fill="none" stroke-dasharray="5 3" class="route-line" marker-end="url(#arrowhead)"/>

        <!-- to Grand Cayman (215,268) -->
        <path id="r-georgetown" d="M 90 170 Q 150 240 210 268" stroke="rgba(0,160,240,0.4)" stroke-width="1.5" fill="none" stroke-dasharray="5 3" class="route-line" marker-end="url(#arrowhead)"/>

        <!-- Destination pins -->

        <!-- Nassau -->
        <circle cx="170" cy="155" r="5" fill="rgba(0,200,255,0.8)" filter="url(#glow)" class="ship-pulse"/>
        <text x="176" y="152" font-family="'IBM Plex Mono'" font-size="7" fill="rgba(0,200,255,0.9)">NASSAU</text>

        <!-- Kingston -->
        <circle cx="260" cy="248" r="5" fill="rgba(0,180,255,0.8)" filter="url(#glow)" class="ship-pulse"/>
        <text x="267" y="246" font-family="'IBM Plex Mono'" font-size="7" fill="rgba(0,180,255,0.9)">KINGSTON</text>

        <!-- San Juan -->
        <circle cx="405" cy="218" r="5" fill="rgba(0,160,255,0.8)" filter="url(#glow)"/>
        <text x="412" y="216" font-family="'IBM Plex Mono'" font-size="7" fill="rgba(0,160,255,0.9)">SAN JUAN</text>

