        <!-- Legend -->
        <rect x="10" y="430" width="200" height="40" fill="rgba(3,11,24,0.8)" stroke="rgba(0,200,255,0.1)" stroke-width="0.5"/>
        <circle cx="25" cy="445" r="4" fill="#00c8ff"/>
        <text x="35" y="448" font-family="'IBM Plex Mono'" font-size="7" fill="rgba(0,200,255,0.7)">Origin Hub — Port Everglades</text>
        <line x1="18" y1="460" x2="35" y2="460" stroke="rgba(0,200,255,0.5)" stroke-width="1.5" stroke-dasharray="5 3"/>
        <text x="40" y="463" font-family="'IBM Plex Mono'" font-size="7" fill="rgba(0,200,255,0.7)">Active Freight Route</text>

        <!-- Scale label -->
        <text x="580" y="465" font-family="'IBM Plex Mono'" font-size="6" fill="rgba(0,100,200,0.4)">CARIBBEAN SEA</text>
        <text x="580" y="475" font-family="'IBM Plex Mono'" font-size="6" fill="rgba(0,100,200,0.3)">© ALP SUPERVOOL 2025</text>
      </svg>
    </div>
  </div>
</section>

<!-- ─── SERVICE TIERS ─── -->
<section id="tiers">
  <div class="section-header fade-up">
    <div class="section-tag">Service Tiers</div>
    <h2 class="section-title">Calibrated<br><span class="accent">Freight Solutions</span></h2>
  </div>

  <div class="tiers-grid">

    <!-- TIER 1 -->
    <div class="tier-card fade-up">
      <div class="tier-badge">TIER 01 — LITE</div>
      <div class="tier-name">Island Link</div>
      <div class="tier-subtitle">// LCL · Small Business · Starter</div>
      <div class="tier-price">$499</div>
      <div class="tier-price-note">starting per LCL shipment</div>
      <div class="tier-divider"></div>
      <ul class="tier-features">
        <li>Less-than-Container Load (LCL) consolidation service</li>
        <li>Local Broward County trucking pickup & delivery</li>
        <li>Port-to-Port freight forwarding to major Caribbean hubs</li>
        <li>Standard customs documentation preparation</li>
        <li>Digital cargo tracking via customer portal</li>
        <li>Email & phone support (business hours)</li>
        <li>Coverage: Nassau, Kingston, San Juan, Grand Cayman</li>
      </ul>
      <button class="tier-cta" onclick="openModal('Island Link')">Select Island Link</button>
    </div>

    <!-- TIER 2 -->
    <div class="tier-card featured fade-up">
      <div class="tier-badge">TIER 02 — ENTERPRISE ★ MOST POPULAR</div>
      <div class="tier-name">Caribbean Core</div>
      <div class="tier-subtitle">// FCL · Door-to-Door · Pro</div>
      <div class="tier-price">$2,400</div>
      <div class="tier-price-note">starting per FCL shipment</div>
      <div class="tier-divider"></div>
      <ul class="tier-features">
        <li>Full Container Load (FCL) — 20ft & 40ft options</li>
        <li>Door-to-door: Broward pickup to island delivery address</li>
        <li>Dedicated trucking routes with priority scheduling</li>
        <li>Priority customs brokerage & clearance</li>
        <li>Refrigerated & hazmat container options</li>
        <li>Real-time GPS container tracking</li>
        <li>Dedicated account manager — 24/7 emergency line</li>
        <li>Full Caribbean network: 18 island destinations</li>
      </ul>
      <button class="tier-cta" onclick="openModal('Caribbean Core')">Select Caribbean Core</button>
    </div>

    <!-- TIER 3 -->
    <div class="tier-card fade-up">
      <div class="tier-badge">TIER 03 — PLATINUM</div>
