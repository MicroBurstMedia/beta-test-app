      <div class="tier-price">Custom</div>
      <div class="tier-price-note">enterprise pricing available</div>
      <div class="tier-divider"></div>
      <ul class="tier-features">
        <li>End-to-end supply chain management & consulting</li>
        <li>Bonded warehouse storage — Broward County facility</li>
        <li>Multi-modal routing: Truck + Sea + Air options</li>
        <li>Multi-island distribution with sequential delivery</li>
        <li>White Glove final-mile island delivery service</li>
        <li>Dedicated logistics coordinator (embedded team)</li>
        <li>Priority berth access at Port Everglades</li>
        <li>Quarterly supply chain audits & optimization reports</li>
      </ul>
      <button class="tier-cta" onclick="openModal('Global Velocity')">Request Enterprise Quote</button>
    </div>

  </div>
</section>

<!-- ─── CALCULATOR ─── -->
<section id="calculator">
  <div class="calc-wrapper">

    <div class="calc-description fade-up">
      <div class="section-tag">Freight Estimator</div>
      <h2 class="section-title" style="margin-bottom:2rem">Instant<br><span class="accent">Quote</span></h2>
      <p>Get a ballpark freight estimate in seconds. Our logistics team will follow up with a binding quote tailored to your exact cargo specifications, insurance requirements, and timeline.</p>

      <ul class="trust-points">
        <li class="trust-point">
          <div class="trust-icon">⚓</div>
          <div>
            <div class="trust-title">Port Everglades Priority Access</div>
            <div class="trust-desc">Dedicated berth relationships mean faster loading and zero delay at Florida's #1 Caribbean freight port.</div>
          </div>
        </li>
        <li class="trust-point">
          <div class="trust-icon">🛡</div>
          <div>
            <div class="trust-title">Bonded & Insured Operations</div>
            <div class="trust-desc">Fully licensed freight forwarder, customs broker, and NVOCC. Your cargo is protected at every handoff.</div>
          </div>
        </li>
        <li class="trust-point">
          <div class="trust-icon">📡</div>
          <div>
            <div class="trust-title">Real-Time Visibility</div>
            <div class="trust-desc">GPS-linked container tracking from Broward pickup through island final delivery. Full chain of custody.</div>
          </div>
        </li>
        <li class="trust-point">
          <div class="trust-icon">🤝</div>
          <div>
            <div class="trust-title">Island Network Partners</div>
            <div class="trust-desc">Established customs agents and trucking operators on every major island — not ad-hoc, but institutional.</div>
          </div>
        </li>
      </ul>
    </div>

    <div class="fade-up">
      <div class="calc-form">
        <div class="form-group">
          <label class="form-label">Service Type</label>
          <div class="service-toggles">
            <button class="service-toggle active" onclick="selectService(this, 'Trucking')">Trucking</button>
            <button class="service-toggle" onclick="selectService(this, 'Ocean Freight')">Ocean Freight</button>
            <button class="service-toggle" onclick="selectService(this, 'Island Delivery')">Island Delivery</button>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Destination Island</label>
          <div class="select-wrapper">
            <select class="form-select" id="calc-dest">
              <option>Nassau, Bahamas</option>
              <option>Kingston, Jamaica</option>
              <option>San Juan, Puerto Rico</option>
              <option>Bridgetown, Barbados</option>
              <option>Port of Spain, Trinidad</option>
              <option>Grand Cayman</option>
              <option>Santo Domingo, DR</option>
              <option>Roseau, Dominica</option>
              <option>Other / Multi-Island</option>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Container Type</label>
          <div class="select-wrapper">
            <select class="form-select" id="calc-container">
              <option value="lcl">LCL — Less-than-Container Load</option>
              <option value="20ft">FCL — 20ft Dry Container</option>
              <option value="40ft">FCL — 40ft Standard</option>
              <option value="40hc">FCL — 40ft High Cube</option>
              <option value="reefer">Reefer (Refrigerated)</option>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Estimated Cargo Weight</label>
          <div class="select-wrapper">
            <select class="form-select" id="calc-weight">
              <option value="1">Under 500 lbs</option>
              <option value="2">500–2,000 lbs</option>
              <option value="3">2,001–10,000 lbs</option>
              <option value="4">10,001–25,000 lbs</option>
              <option value="5">25,000+ lbs (Full Load)</option>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Additional Services</label>
          <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
            <label style="display:flex;align-items:center;gap:0.4rem;font-family:var(--font-mono);font-size:0.65rem;color:var(--muted);cursor:pointer;">
              <input type="checkbox" id="add-customs" style="accent-color:var(--blue-neon)"> Customs Brokerage
            </label>
            <label style="display:flex;align-items:center;gap:0.4rem;font-family:var(--font-mono);font-size:0.65rem;color:var(--muted);cursor:pointer;margin-left:1rem;">
              <input type="checkbox" id="add-insurance" style="accent-color:var(--blue-neon)"> Cargo Insurance
            </label>
            <label style="display:flex;align-items:center;gap:0.4rem;font-family:var(--font-mono);font-size:0.65rem;color:var(--muted);cursor:pointer;margin-left:1rem;">
              <input type="checkbox" id="add-warehouse" style="accent-color:var(--blue-neon)"> Warehousing
            </label>
          </div>
        </div>

        <button class="calc-btn" onclick="calculateQuote()">Calculate Estimate ▸</button>

        <div class="calc-result" id="calc-result">
          <div class="result-label">Estimated Freight Range</div>
          <div class="result-range" id="result-range">$0 – $0</div>
          <div class="result-note" id="result-note">Based on standard rates. Contact us for a binding quote.</div>
          <button class="calc-btn" style="margin-top:1rem; background: rgba(0,200,255,0.1); color: var(--blue-neon); border: 1px solid rgba(0,200,255,0.3);" onclick="openModal()">Get Binding Quote →</button>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ─── PROCESS ─── -->
<section id="process">
  <div class="section-header fade-up" style="text-align:center">
    <div class="section-tag" style="justify-content:center">Operational Flow</div>
    <h2 class="section-title">How <span class="accent">Supervool</span> Moves<br>Your Freight</h2>
  </div>

  <div class="process-flow fade-up">
    <div class="process-step">
      <div class="step-number">01</div>
      <div class="step-title">Cargo Pickup</div>
      <div class="step-desc">Our Broward trucking fleet collects from your facility or warehouse anywhere in South Florida.</div>
    </div>
    <div class="process-step">
      <div class="step-number">02</div>
      <div class="step-title">Port Processing</div>
      <div class="step-desc">Cargo arrives at Port Everglades. Our dock team manages documentation, container stuffing, and pre-clearance filing.</div>
    </div>
    <div class="process-step">
      <div class="step-number">03</div>
      <div class="step-title">Ocean Transit</div>
      <div class="step-desc">Your container departs on our scheduled Caribbean sailings. Real-time GPS tracking active from day one.</div>
    </div>
    <div class="process-step">
      <div class="step-number">04</div>
      <div class="step-title">Customs Clearance</div>
      <div class="step-desc">Our island-side customs brokers handle all import documentation for fast, compliant port release.</div>
    </div>
    <div class="process-step">
      <div class="step-number">05</div>
      <div class="step-title">Island Delivery</div>
      <div class="step-desc">Last-mile trucking partners deliver door-to-door on the island. Signature confirmation & proof of delivery sent to you.</div>
    </div>
  </div>
</section>

<!-- ─── CTA BAND ─── -->
<section id="cta">
  <div class="cta-super">Ready to Ship?</div>
  <h2 class="cta-headline">
    The Caribbean<br>
    <span class="accent">Runs On Supervool.</span>
  </h2>
  <p class="cta-sub">Join hundreds of importers, exporters, and distributors who trust ALP Supervool LLC to keep their Caribbean supply chains moving — with zero disruption and maximum velocity.</p>
  <div class="cta-actions">
    <button class="btn-primary" onclick="openModal()">Start Your Shipment</button>
    <button class="btn-secondary" onclick="document.getElementById('calculator').scrollIntoView({behavior:'smooth'})">Estimate Freight Cost</button>
  </div>
</section>

<!-- ─── FOOTER ─── -->
<footer>
  <div class="footer-logo">ALP <span>SUPERVOOL</span> LLC</div>
  <div class="footer-links">
    <a href="#">Port Everglades, FL</a>
    <a href="#">Broward County Hub</a>
    <a href="#">Caribbean Routes</a>
    <a href="#">Customs Brokerage</a>
    <a href="#">Contact</a>
  </div>
  <div class="footer-copy">© 2025 ALP Supervool LLC. All rights reserved.</div>
</footer>

<!-- ─── MODAL ─── -->
<div class="modal-overlay" id="modal-overlay" onclick="handleOverlayClick(event)">
  <div class="modal">
    <button class="modal-close" onclick="closeModal()">✕</button>
    <div class="modal-title">Start Your<br><span style="color:var(--blue-neon)">Shipment</span></div>
    <div class="modal-sub" id="modal-sub">// OPERATIONS INQUIRY</div>
    <div class="form-group">
      <label class="form-label">Full Name</label>
      <input type="text" class="form-input" placeholder="Your name">
    </div>
    <div class="form-group">
      <label class="form-label">Company</label>
      <input type="text" class="form-input" placeholder="Company name">
    </div>
    <div class="form-group">
      <label class="form-label">Email Address</label>
      <input type="email" class="form-input" placeholder="your@email.com">
    </div>
    <div class="form-group">
      <label class="form-label">Phone Number</label>
      <input type="tel" class="form-input" placeholder="+1 (954) 000-0000">
    </div>
    <div class="form-group">
      <label class="form-label">Message / Shipment Details</label>
      <textarea class="form-input" rows="3" placeholder="Describe your cargo, destination, and timeline…" style="resize:vertical"></textarea>
    </div>
    <button class="calc-btn" onclick="submitForm()">Send to Operations Team →</button>
  </div>
</div>

<script>
  // ── SCROLL FADE IN ──
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        const children = e.target.querySelectorAll('.fade-up');
        children.forEach((c, i) => {
          setTimeout(() => c.classList.add('visible'), i * 120);
        });
      }
    });
  }, { threshold: 0.12 });

  document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

  // ── SERVICE TOGGLES ──
  let selectedService = 'Trucking';
  function selectService(btn, service) {
    document.querySelectorAll('.service-toggle').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    selectedService = service;
  }

  // ── QUOTE CALCULATOR ──
  const basePrices = {
    lcl: { min: 350, max: 900 },
    '20ft': { min: 1800, max: 3200 },
    '40ft': { min: 2800, max: 5000 },
    '40hc': { min: 3200, max: 5800 },
    reefer: { min: 4000, max: 7500 }
  };

  const destinationMultiplier = {
    'Nassau, Bahamas': 1.0,
    'Kingston, Jamaica': 1.3,
    'San Juan, Puerto Rico': 1.15,
    'Bridgetown, Barbados': 1.45,
    'Port of Spain, Trinidad': 1.5,
    'Grand Cayman': 1.25,
    'Santo Domingo, DR': 1.2,
    'Roseau, Dominica': 1.55,
    'Other / Multi-Island': 1.6
  };

  const weightMultiplier = { '1': 0.6, '2': 0.8, '3': 1.0, '4': 1.2, '5': 1.4 };

  const serviceAdder = {
    'Trucking': 0, 'Ocean Freight': 200, 'Island Delivery': 350
  };

  function calculateQuote() {
    const container = document.getElementById('calc-container').value;
    const dest = document.getElementById('calc-dest').value;
    const weight = document.getElementById('calc-weight').value;
    const hasCustoms = document.getElementById('add-customs').checked;
    const hasInsurance = document.getElementById('add-insurance').checked;
    const hasWarehouse = document.getElementById('add-warehouse').checked;

    const base = basePrices[container];
    const dm = destinationMultiplier[dest] || 1.0;
    const wm = weightMultiplier[weight] || 1.0;
    const sa = serviceAdder[selectedService] || 0;
    const extras = (hasCustoms ? 280 : 0) + (hasInsurance ? 150 : 0) + (hasWarehouse ? 400 : 0);

    const low = Math.round((base.min * dm * wm) + sa + extras);
    const high = Math.round((base.max * dm * wm) + sa + extras);

    const resultEl = document.getElementById('calc-result');
    const rangeEl = document.getElementById('result-range');
    const noteEl = document.getElementById('result-note');

    rangeEl.textContent = `$${low.toLocaleString()} – $${high.toLocaleString()}`;
    noteEl.textContent = `${selectedService} · ${container.toUpperCase()} · ${dest}. Estimate only — contact us for binding rate.`;
    resultEl.classList.add('visible');

    resultEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  // ── MAP ROUTE HIGHLIGHT ──
  function highlightRoute(id) {
    document.querySelectorAll('[id^="r-"]').forEach(p => {
      p.style.stroke = '';
      p.style.strokeWidth = '';
      p.style.opacity = '1';
    });
    const el = document.getElementById('r-' + id);
    if (el) {
      el.style.stroke = '#00c8ff';
      el.style.strokeWidth = '2.5';
      el.style.opacity = '1';
      document.querySelectorAll('[id^="r-"]').forEach(p => {
        if (p !== el) p.style.opacity = '0.25';
      });
      setTimeout(() => {
        document.querySelectorAll('[id^="r-"]').forEach(p => {
          p.style.stroke = '';
          p.style.strokeWidth = '';
          p.style.opacity = '1';
        });
      }, 3000);
    }
  }

  // ── MODAL ──
  function openModal(tier) {
    const overlay = document.getElementById('modal-overlay');
    const sub = document.getElementById('modal-sub');
    if (tier) sub.textContent = `// ${tier.toUpperCase()} PACKAGE INQUIRY`;
    else sub.textContent = '// OPERATIONS INQUIRY';
    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    document.getElementById('modal-overlay').classList.remove('open');
    document.body.style.overflow = '';
  }

  function handleOverlayClick(e) {
    if (e.target === document.getElementById('modal-overlay')) closeModal();
  }

  function submitForm() {
    const btn = event.target;
    btn.textContent = 'Message Sent ✓';
    btn.style.background = 'rgba(0,200,255,0.1)';
    btn.style.color = 'var(--blue-neon)';
    btn.style.border = '1px solid rgba(0,200,255,0.3)';
    setTimeout(closeModal, 1800);
  }

  // Escape key closes modal
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
</script>
</body>
</html>
